# Copy to .env and fill in your values before running docker-compose

# Your production domain
ALLOWED_ORIGIN=https://tincan.example.com

# The URL the browser uses to reach the signaling server
# (same domain, routed by nginx to the server container)
NEXT_PUBLIC_SIGNAL_URL=https://tincan.example.com

# Secret key for the /health endpoint — generate with: openssl rand -hex 32
HEALTH_API_KEY=changeme

# TURN server — coturn or Twilio
TURN_URL=turn:turn.example.com:3478
# Shared secret for HMAC credentials (coturn: static-auth-secret)
# Generate with: openssl rand -hex 32
TURN_SECRET=changeme
