# Server port
PORT=3001

# Lock CORS to your frontend domain (never use * in production)
ALLOWED_ORIGIN=https://your-domain.com

# Set to "true" when running behind nginx / AWS ALB / Cloudflare
# Allows reading the real client IP from X-Forwarded-For
# Leave "false" (default) for local dev to prevent IP spoofing
TRUST_PROXY=false

# TURN server credentials (kept server-side — never sent to client as static env)
# Served via the /turn-credentials endpoint with a TTL
TURN_URL=turn:your-turn-server.com:3478
TURN_USER=your_username
TURN_PASS=your_password
